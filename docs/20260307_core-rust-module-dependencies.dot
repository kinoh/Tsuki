digraph {
    graph [rankdir=LR, newrank=true, concentrate=true, ranksep=1.0, nodesep=0.4, pad=0.3, fontname="Helvetica", fontsize="24", label="core-rust internal dependencies", labelloc=t];
    node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize="11", color="#7a7a7a", penwidth=1.0, margin="0.10,0.06"];
    edge [color="#7f8c8d", arrowsize=0.7, penwidth=1.0, fontname="Helvetica", fontsize="9"];

    subgraph cluster_entry {
        label="Entry";
        color="#d0d7de";
        penwidth=1.0;
        style="rounded";
        rank=same;
        "tsuki_core_rust" [label="crate root", fillcolor="#d9ecff"];
        "tsuki_core_rust::cli" [label="cli", fillcolor="#d9ecff"];
        "tsuki_core_rust::commands::backfill" [label="commands/backfill", fillcolor="#d9ecff"];
        "tsuki_core_rust::server_app" [label="server_app", fillcolor="#d9ecff"];
    }

    subgraph cluster_application {
        label="Application";
        color="#d0d7de";
        penwidth=1.0;
        style="rounded";
        rank=same;
        "tsuki_core_rust::application::debug_service" [label="debug_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::event_service" [label="event_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::execution_service" [label="execution_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::history_service" [label="history_service", fillcolor="#dcf5e4"];
