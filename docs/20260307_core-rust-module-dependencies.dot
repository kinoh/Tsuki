        "tsuki_core_rust::application::improve_service" [label="improve_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::module_bootstrap" [label="module_bootstrap", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::pipeline_service" [label="pipeline_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::router_service" [label="router_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::scheduler_notice_service" [label="scheduler_notice_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::scheduler_service" [label="scheduler_service", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::trigger_ingress_api" [label="trigger_ingress_api", fillcolor="#dcf5e4"];
        "tsuki_core_rust::application::usage_service" [label="usage_service", fillcolor="#dcf5e4"];
    }

    subgraph cluster_core {
        label="Core";
        color="#d0d7de";
        penwidth=1.0;
        style="rounded";
        rank=same;
        "tsuki_core_rust::clock" [label="clock", fillcolor="#fff2cc"];
        "tsuki_core_rust::config" [label="config", fillcolor="#fff2cc"];
        "tsuki_core_rust::event" [label="event", fillcolor="#fff2cc"];
        "tsuki_core_rust::event::contracts" [label="event::contracts", fillcolor="#fff2cc"];
        "tsuki_core_rust::module_registry" [label="module_registry", fillcolor="#fff2cc"];
        "tsuki_core_rust::prompts" [label="prompts", fillcolor="#fff2cc"];
    }

    subgraph cluster_storage {
        label="Storage";
        color="#d0d7de";
        penwidth=1.0;
        style="rounded";
        rank=same;
        "tsuki_core_rust::db" [label="db", fillcolor="#fde2d2"];
        "tsuki_core_rust::event_store" [label="event_store", fillcolor="#fde2d2"];
        "tsuki_core_rust::notification" [label="notification", fillcolor="#fde2d2"];
        "tsuki_core_rust::scheduler" [label="scheduler", fillcolor="#fde2d2"];
        "tsuki_core_rust::state" [label="state", fillcolor="#fde2d2"];
    }

    subgraph cluster_integration {
        label="Integration";
        color="#d0d7de";
        penwidth=1.0;
        style="rounded";
        rank=same;
